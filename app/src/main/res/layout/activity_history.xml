<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/background"
                android:padding="24dp">

    <!-- === EXACT HEADER BLOCK FROM MAIN SCREEN === -->
    <RelativeLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp">

        <ImageView
                android:id="@+id/logoSmall"
                android:layout_width="120dp"
                android:layout_height="24dp"
                android:layout_centerInParent="true"
                android:src="@drawable/masv_logo"
                android:scaleType="fitCenter"
                android:contentDescription="MASV Logo" />

        <ImageButton
                android:id="@+id/themeToggleButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:background="@android:color/transparent"
                app:srcCompat="@drawable/ic_theme_toggle"
                android:tint="@color/icon_tint"
                android:contentDescription="Toggle theme" />

        <ImageButton
                android:id="@+id/moreButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:background="@android:color/transparent"
                app:srcCompat="@drawable/ic_more_vert"
                android:tint="@color/icon_tint"
                android:contentDescription="More options" />
    </RelativeLayout>

    <!-- === Centred "Upload History" title === -->
    <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/headerLayout"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="24dp"
            android:text="Upload History"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium" />

    <!-- Empty state (centred, below title) -->
    <TextView
            android:id="@+id/emptyStateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/titleText"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="48dp"
            android:text="No upload history yet."
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

    <!-- RecyclerView (below title) -->
    <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/titleText"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

</RelativeLayout>