<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
                                   xmlns:app="http://schemas.android.com/apk/res-auto"
                                   android:layout_width="match_parent"
                                   android:layout_height="wrap_content"
                                   android:layout_marginBottom="8dp"
                                   app:cardCornerRadius="8dp"
                                   app:cardElevation="2dp"
                                   app:cardBackgroundColor="@color/card_bg">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

        <TextView
                android:id="@+id/packageNameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Package Name"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium" />

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

            <TextView
                    android:id="@+id/packageStateText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OPEN"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:padding="4dp"
                    android:background="@drawable/status_badge" />

            <TextView
                    android:id="@+id/packageDateText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2025-01-01"
                    android:textSize="12sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginStart="12dp" />

            <TextView
                    android:id="@+id/packageFilesText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 files"
                    android:textSize="12sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginStart="12dp" />
        </LinearLayout>
        <!-- Container for expanded file list -->
        <LinearLayout
                android:id="@+id/filesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="8dp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>