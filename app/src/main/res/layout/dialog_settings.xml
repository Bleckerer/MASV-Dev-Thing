<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="vertical"
              android:padding="24dp"
              android:background="@color/background">

    <!-- Scan Interval -->
    <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scan interval (minutes)"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

    <EditText
            android:id="@+id/scanIntervalEditText"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/input_field_bg"
            android:inputType="number"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:fontFamily="sans-serif"
            android:layout_marginBottom="16dp" />

    <!-- Upload Retry Interval -->
    <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload retry interval (minutes)"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

    <EditText
            android:id="@+id/uploadIntervalEditText"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/input_field_bg"
            android:inputType="number"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:fontFamily="sans-serif"
            android:layout_marginBottom="16dp" />

    <!-- Extensions -->
    <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Extensions"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

    <LinearLayout
            android:id="@+id/extensionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp" />

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

        <EditText
                android:id="@+id/newExtensionEditText"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/input_field_bg"
                android:hint="e.g., jpg"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:fontFamily="sans-serif" />

        <Button
                android:id="@+id/addExtensionButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:text="Add"
                android:textSize="14sp"
                android:textColor="@color/button_secondary_text"
                android:background="@drawable/btn_secondary_light"
                android:paddingLeft="16dp"
                android:paddingRight="16dp" />
    </LinearLayout>

    <!-- Divider -->
    <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

    <!-- Logout Button (destructive outline) -->
    <Button
            android:id="@+id/logoutButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Logout"
            android:textSize="15sp"
            android:textColor="@color/button_destructive_text"
            android:background="@drawable/btn_logout_gradient"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:gravity="center"
            android:fontFamily="sans-serif-medium" />

</LinearLayout>